{
	"name": "@repo/db",
	"version": "1.0.0",
	"description": "Shared Drizzle ORM database client for the monorepo",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./schema": "./src/schema.ts"
	},
	"scripts": {
		"db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
		"db:push": "dotenv -e ../../.env -- drizzle-kit push",
		"db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
		"db:studio": "dotenv -e ../../.env -- drizzle-kit studio"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.7"
	},
	"devDependencies": {
		"@types/node": "^22.15.3",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.0",
		"typescript": "5.9.2"
	}
}
